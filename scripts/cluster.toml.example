# nyc bare-metal inventory. Copy to cluster.toml and fill in.
# Used by scripts/preflight.py and scripts/deploy.py.

[cluster]
ssh_user   = "ubuntu"                                # passwordless-sudo login user
ref        = "main"                                  # equator git ref to deploy
repo_url   = "git@github.com:the-bokya/equator.git"  # cloned recursively via forwarded agent
remote_dir = "~/equator"                             # checkout location on each node
vpc_cidr   = "172.16.0.0/16"                          # default VPC; MUST NOT overlap the underlay
dns        = "1.1.1.1"                                # resolver baked into guest VMs
vm_ttl_minutes = 0                                    # auto-delete VMs N minutes after creation (0 = never)
lvm_vg     = "nyc"                                    # volume group nyc creates on each node's device
lvm_thinpool = "pool"                                 # thin pool inside that VG (volumes/snapshots/rootfs)
http_port  = 8000
rqlite_http_port = 4001
rqlite_raft_port = 4002
vm_domain  = "example.com"                            # VM routing root domain; operator points *.example.com to the proxy VM public IP
public_bridge = "pub0"                                # bridge over the public NIC (created once at provision)

# One node must have bootstrap = true; the rest join it.
# host        = private/underlay IP (raft + cross-node proxy + VXLAN endpoints)
# public_host = public IPv4 (control reaches it here; ssh jump server)
# domain      = per-node control API domain (host Caddy gets a TLS cert for this);
#               must resolve to public_host. SEPARATE from [cluster] vm_domain.
# lvm_device  = the ONE block device nyc owns + LVM-formats on this node (set per machine;
#               device names differ). nyc runs pvcreate/vgcreate/thin-pool on it at startup,
#               only when the VG is absent and the device is empty (NYC_LVM_FORCE=1 overrides).
#               Omit to fall back to a loopback file (dev only).
#
# Public IP setup (macvtap-style L2, no DNAT/SNAT):
#   Each VM that needs a public IP gets a second NIC (eth1) bridged directly onto pub0.
#   pub0 is a Linux bridge over public_iface, created once at provision.
#   Each public IP entry carries the provider-registered MAC — the provider's L2 anti-spoof
#   accepts frames only from the registered MAC, so the MAC is mandatory.
#   public_host_cidr = the host's own IP on the public NIC (moved onto pub0 at provision).
[[nodes]]
name = "n1"
host = "10.0.0.11"
public_host = "203.0.113.1"
domain = "n1.example.com"
lvm_device = "/dev/nvme1n1"
bootstrap = true
public_iface      = "ens3"
public_host_cidr  = "203.0.113.1/28"           # host's own IP on ens3 — moved to pub0
pubip_gateway     = "62.210.0.1"               # Scaleway default gateway for flexible IPs
[[nodes.public_ips]]
address = "203.0.113.10"
mac     = "de:ad:be:ef:00:01"
[[nodes.public_ips]]
address = "203.0.113.11"
mac     = "de:ad:be:ef:00:02"

[[nodes]]
name = "n2"
host = "10.0.0.12"
public_host = "203.0.113.2"
domain = "n2.example.com"
lvm_device = "/dev/nvme1n1"
public_iface      = "ens3"
public_host_cidr  = "203.0.113.2/28"
pubip_gateway     = "62.210.0.1"
[[nodes.public_ips]]
address = "203.0.113.20"
mac     = "de:ad:be:ef:00:10"
